# ── Devin ──────────────────────────────────────────────────────────────────────
DEVIN_API_KEY=apk_your_key_here

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_OWNER=your-github-org-or-username
GITHUB_REPO=superset

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://devin:devin@postgres:5432/devin_orchestrator
# Read-only user for analytics queries (safe SQL execution)
DATABASE_URL_RO=postgresql+asyncpg://analytics_ro:analytics_ro_pass@postgres:5432/devin_orchestrator

# ── Tunables ───────────────────────────────────────────────────────────────────
# Set to true when using smee (bypasses HMAC check; smee uses its own channel signing)
SKIP_WEBHOOK_SIGNATURE=false
APP_ENV=development
MAX_ACU_LIMIT=50
MAX_ATTEMPTS=3
AUTO_REMEDIATE_LABEL=devin:auto-remediate
ANALYTICS_ROW_LIMIT=500
ANALYTICS_TIMEOUT_MS=10000
# How often the background poller checks Devin sessions (seconds)
POLL_INTERVAL_SECONDS=30
